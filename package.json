{
  "name": "restless",
  "version": "1.2.1",
  "description": "Restless - Bruno-style desktop application",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "electron:dev": "tsc -p tsconfig.electron.json && concurrently -k \"vite\" \"wait-on http-get://127.0.0.1:5173 && electron . --no-sandbox --disable-gpu\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:win:arm": "npm run build && electron-builder --win --arm64",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "api",
    "client",
    "http",
    "postman",
    "electron"
  ],
  "author": {
    "name": "Dobrosav Vlaskovic",
    "email": "vlaskovic.dodo@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/conf": "^2.1.0",
    "@types/md5": "^2.3.6",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.7",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "axios": "^1.13.6",
    "curlconverter": "^4.12.0",
    "dompurify": "^3.3.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "md5": "^2.3.0",
    "quicktype-core": "^23.2.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-syntax-highlighter": "^16.1.1",
    "simple-git": "^3.32.3",
    "uuid": "^13.0.0"
  },
  "overrides": {
    "dompurify": "^3.3.3"
  },
  "build": {
    "npmRebuild": false,
    "appId": "com.restless.app",
    "productName": "Restless",
    "artifactName": "restless-setup-${arch}.${ext}",
    "icon": "./public/logo.ico",
    "extraResources": [
      {
        "from": "public/logo.png",
        "to": "logo.png"
      },
      {
        "from": "public/logo.ico",
        "to": "logo.ico"
      }
    ],
    "asarUnpack": [
      "dist/logo.png"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Dobrosav",
        "repo": "restless"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "./public/icon-512.png"
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "./public/icon-512.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "./public/icon-512.png"
    },
    "deb": {
      "priority": "optional",
      "depends": [
        "libnotify4",
        "libxtst6",
        "libnss3"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
